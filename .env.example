# Environment Configuration
# Copy this file to .env and fill in your API keys

# ===== LLM API Keys =====
# Gemini API Key (Get from: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Get from: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# ===== Model Configuration =====
MODEL_PATH=models/fracatlas/efficientnet_b0_final.h5
ENSEMBLE_MODE=single  # single or ensemble

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ===== Frontend Configuration =====
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== Monitoring =====
LOG_LEVEL=INFO
ENABLE_METRICS=true
PROMETHEUS_PORT=9090

# ===== Database (Optional) =====
# DATABASE_URL=postgresql://user:password@localhost:5432/fracture_db

# ===== Storage =====
UPLOAD_DIR=temp/uploads
RESULTS_DIR=temp/results

# ===== Security =====
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== Performance =====
MAX_UPLOAD_SIZE=10485760  # 10MB
REQUEST_TIMEOUT=30

# ===== Feature Flags =====
ENABLE_QA_SYSTEM=true
ENABLE_EXPLAINABILITY=true
ENABLE_FEEDBACK=true
ENABLE_MONITORING=true
