# .dockerignore
# Exclude files from Docker context to reduce build time and image size

__pycache__
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.git
.gitignore
.mypy_cache
.pytest_cache
.uv
tmp/
data/
# Don't exclude config files needed for runtime
# But exclude local secrets
.env
.env.local
